#! /bin/bash

# Function to get next available version
get_next_version() {
    local base_version="$1"
    local major minor patch
    local current_version="$base_version"
    
    # Parse version components (e.g., v0.0.1 -> 0, 0, 1)
    if [[ "$current_version" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
        major="${BASH_REMATCH[1]}"
        minor="${BASH_REMATCH[2]}"
        patch="${BASH_REMATCH[3]}"
    else
        echo "Error: Invalid version format. Expected format: vX.Y.Z" >&2
        exit 1
    fi
    
    # Keep incrementing patch version until we find an available one
    while true; do
        # Check if this version exists on GitHub (check tags, not releases)
        CODE=$(curl -s -o /dev/null -I -w "%{http_code}" "https://api.github.com/repos/rampart-aios/netboot.xyz/git/refs/tags/${current_version}")
        
        if [[ "$CODE" == "404" ]]; then
            # Version doesn't exist, we can use it
            echo "$current_version"
            return 0
        elif [[ "$CODE" == "200" ]]; then
            # Version exists, increment patch and try again
            patch=$((patch + 1))
            current_version="v${major}.${minor}.${patch}"
        else
            echo "Error: GitHub API returned status code $CODE" >&2
            exit 1
        fi
    done
}

# Main execution
if [[ -z "$RELEASE_TAG" ]]; then
    echo "Error: RELEASE_TAG environment variable not set" >&2
    exit 1
fi

# Configure git if not already configured
if [[ -z "$(git config user.email)" ]]; then
    git config user.email "action@github.com"
    git config user.name "GitHub Action"
fi

# Get the next available version
NEXT_VERSION=$(get_next_version "$RELEASE_TAG")
echo "Next available version: $NEXT_VERSION"

# Create the tag (force overwrite if it exists locally)
git tag -f "$NEXT_VERSION"

# Output the version for the workflow to use
if [[ -n "$GITHUB_ENV" ]]; then
    echo "VERSION_TAG=$NEXT_VERSION" >> $GITHUB_ENV
fi
echo "VERSION_TAG=$NEXT_VERSION"
