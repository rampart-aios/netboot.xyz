#!/bin/bash
set -e

NBXYZ_OVERRIDES=default
BUILDOUT_DIR="buildout/ipxe"
GITHUBOUT_DIR="githubout"
EFI_SOURCE_FILE="netboot.xyz.efi"
SHORT_COMMIT=${GITHUB_SHA:0:7}

# Get branch name and short commit hash for rampart-aios naming
if [[ -n "${GITHUB_HEAD_REF}" ]]; then
  # PR event: use source branch name
  BRANCH_NAME="${GITHUB_HEAD_REF}"
elif [[ -n "${GITHUB_REF_NAME}" ]]; then
  # Push event: use current branch name
  BRANCH_NAME="${GITHUB_REF_NAME}"
else
  # Fallback: use git to get branch name
  BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
fi

# Clean branch name (remove any path separators or special characters)
BRANCH_NAME=$(echo "${BRANCH_NAME}" | sed 's/[^a-zA-Z0-9_-]/-/g')

echo "Building for branch: ${BRANCH_NAME} (${SHORT_COMMIT})"

# Check prerequisites
if ! command -v docker &> /dev/null; then
    echo "Error: Docker is not installed or not in PATH"
    exit 1
fi

# Build release
echo "Building Docker image..."
docker build -t localbuild --build-arg NBXYZ_OVERRIDES=${NBXYZ_OVERRIDES} .

echo "Running Docker container..."
docker run --rm -i -v $(pwd):/buildout localbuild

# Verify build output and rename EFI file
if [[ -f "${BUILDOUT_DIR}/${EFI_SOURCE_FILE}" ]]; then
  EFI_FILE_NAME="netboot.xyz-rampart-aios-${BRANCH_NAME}-${SHORT_COMMIT}.efi"
  
  # Rename EFI file
  mv "${BUILDOUT_DIR}/${EFI_SOURCE_FILE}" "${BUILDOUT_DIR}/${EFI_FILE_NAME}"
  echo "EFI_FILE_NAME=${EFI_FILE_NAME}"
  
  # Create githubout with EFI for release
  mkdir -p "${GITHUBOUT_DIR}"
  cp "${BUILDOUT_DIR}/${EFI_FILE_NAME}" "${GITHUBOUT_DIR}/"
  ls -la "${GITHUBOUT_DIR}/"
  
  echo "Build completed successfully"
else
  echo "Error: ${EFI_SOURCE_FILE} not found in ${BUILDOUT_DIR}/"
  ls -la "${BUILDOUT_DIR}/" || echo "Directory is empty or does not exist"
  exit 1
fi
