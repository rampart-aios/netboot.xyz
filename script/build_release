#!/bin/bash
set -e

# Configuration
NBXYZ_OVERRIDES=default

# Get branch name and short commit hash for rampart-aios naming
if [[ -n "${GITHUB_HEAD_REF}" ]]; then
  # PR event: use source branch name
  BRANCH_NAME="${GITHUB_HEAD_REF}"
  echo "PR event detected - using source branch: ${BRANCH_NAME}"
elif [[ -n "${GITHUB_REF_NAME}" ]]; then
  # Push event: use current branch name
  BRANCH_NAME="${GITHUB_REF_NAME}"
  echo "Push event detected - using current branch: ${BRANCH_NAME}"
else
  # Fallback: use git to get branch name
  BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
  echo "Fallback - using git branch: ${BRANCH_NAME}"
fi

SHORT_COMMIT=${GITHUB_SHA:0:7}

# Clean branch name (remove any path separators or special characters)
BRANCH_NAME=$(echo "${BRANCH_NAME}" | sed 's/[^a-zA-Z0-9_-]/-/g')

echo "Building for branch: ${BRANCH_NAME}"
echo "Commit hash: ${GITHUB_SHA:-$(git rev-parse HEAD)}"
echo "Short commit: ${SHORT_COMMIT}"
echo "Cleaned branch name: ${BRANCH_NAME}"
echo "Event context: GITHUB_HEAD_REF=${GITHUB_HEAD_REF}, GITHUB_REF_NAME=${GITHUB_REF_NAME}"

# Build release
echo "Building Docker image with NBXYZ_OVERRIDES=${NBXYZ_OVERRIDES}..."
docker build -t localbuild --build-arg NBXYZ_OVERRIDES=${NBXYZ_OVERRIDES} .

echo "Running Docker container to generate build artifacts..."
docker run --rm -i -v $(pwd):/buildout localbuild

# Debug: List contents of buildout/ipxe directory
echo "Contents of buildout/ipxe directory:"
ls -la buildout/ipxe/ || echo "Directory buildout/ipxe/ does not exist"

# Rename netboot.xyz.efi to rampart-aios convention
if [[ -f "buildout/ipxe/netboot.xyz.efi" ]]; then
  NEW_NAME="netboot.xyz-rampart-aios-${BRANCH_NAME}-${SHORT_COMMIT}.efi"
  mv "buildout/ipxe/netboot.xyz.efi" "buildout/ipxe/${NEW_NAME}"
  echo "Successfully renamed to ${NEW_NAME}"
  echo "NEW_NAME=${NEW_NAME}"
else
  echo "Error: netboot.xyz.efi not found in buildout/ipxe/"
  ls -la buildout/ipxe/ || echo "Directory is empty or does not exist"
  exit 1
fi
